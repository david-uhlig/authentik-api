#!/bin/bash -e
# Auto generates the authentik OpenAPI client for `../.authentik/schema.yaml`.
#
# Uses the official OpenAPI Generator Docker container for the generation process.
script_dir="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
project_base_path="$( cd "$script_dir/.." && pwd )"
docker_mount_path="/local"
authentik_version="$(yq -r '.info.version' "${project_base_path}/.authentik/schema.yaml")"
gem_version=$(echo "$authentik_version" | tr "-" ".")
output_path="${project_base_path}/tmp"

if [[ -z "$authentik_version" || "$authentik_version" == "null" ]]; then
  echo "Error: Authentik version (.info.version) not found in ${project_base_path}/.authentik/schema.yaml" >&2
  exit 1
fi

# Cleanup previously generated files.
rm -rf "${output_path}"

# Generate API into temp path.
docker run --rm \
  --user "$(id -u)":"$(id -g)" \
  -v ${project_base_path}:${docker_mount_path} openapitools/openapi-generator-cli generate \
  --config ${docker_mount_path}/.openapi-generator/config.yaml \
  --input-spec ${docker_mount_path}/.authentik/schema.yaml \
  --template-dir ${docker_mount_path}/.openapi-generator/ruby-templates \
  --additional-properties=gemVersion=${gem_version} \
  --output "${docker_mount_path}/tmp" \
  --generator-name ruby \
  > /dev/null

# Postprocess.
"${script_dir}/postprocess-api" "${output_path}"
